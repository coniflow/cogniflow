{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "CogniFlow",
  "version": "1.0.0",
  "identifier": "com.cogniflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CogniFlow",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "windowEffects": {
          "effects": ["blur", "acrylic"]
        }
      },
      {
        "title": "Quick Capture",
        "label": "capture",
        "url": "http://localhost:1420/#/capture",
        "width": 600,
        "height": 400,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "focus": true,
        "visible": false,
        "windowEffects": {
          "effects": ["blur", "acrylic"]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
